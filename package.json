{
  "name": "course-clip-studio",
  "version": "0.1.0",
  "productName": "Course Clip Studio",
  "description": "Course Clip Studio — Cross-platform desktop course authoring application",
  "main": "./out/main/index.js",
  "author": "Rocco Catrone",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder --mac --dir",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:all": "electron-vite build && electron-builder -mwl",
    "install-app": "npm run dist && codesign --force --deep --sign - \"dist/mac-arm64/Course Clip Studio.app\" && rm -rf \"/Applications/Course Clip Studio.app\" && cp -R \"dist/mac-arm64/Course Clip Studio.app\" \"/Applications/Course Clip Studio.app\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test"
  },
  "build": {
    "appId": "com.course-clip-studio",
    "productName": "Course Clip Studio",
    "protocols": {
      "name": "Course Clip Studio",
      "schemes": [
        "lumina"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Tech-Inclusion-Pro",
      "repo": "Course_Clip_Studio"
    },
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Education",
      "mimeTypes": [
        "x-scheme-handler/lumina"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/splash.html",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "resources/splash.html",
        "to": "splash.html"
      }
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@tiptap/extension-color": "^3.21.0",
    "@tiptap/extension-highlight": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-text-style": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^5.5.9",
    "i18next": "^26.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.28.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
}
