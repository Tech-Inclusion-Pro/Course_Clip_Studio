{
  "name": "course-clip-studio",
  "version": "0.1.0",
  "productName": "Course Clip Studio",
  "description": "Course Clip Studio — Cross-platform desktop course authoring application",
  "main": "./out/main/index.js",
  "author": "Rocco Catrone",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder --mac --dir",
    "install-app": "npm run dist && codesign --force --deep --sign - \"dist/mac-arm64/Course Clip Studio.app\" && rm -rf \"/Applications/Course Clip Studio.app\" && cp -R \"dist/mac-arm64/Course Clip Studio.app\" \"/Applications/Course Clip Studio.app\""
  },
  "build": {
    "appId": "com.course-clip-studio",
    "productName": "Course Clip Studio",
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.education",
      "target": "dir"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!node_modules"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tiptap/extension-color": "^3.21.0",
    "@tiptap/extension-highlight": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-text-style": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
